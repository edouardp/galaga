    {
      "id": "qnkX",
      "code_hash": "9a1e23aa6d25117fd23febc8b7ba30ee",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"electromagnetic-field-bivector\">Electromagnetic Field Bivector</h2>\n<span class=\"paragraph\">In STA, the electromagnetic field is a single bivector <marimo-tex class=\"arithmatex\">||(F||)</marimo-tex>:</span>\n<marimo-tex class=\"arithmatex\">||[F = \\mathbf{E} + I\\mathbf{B}||]</marimo-tex><span class=\"paragraph\">where <marimo-tex class=\"arithmatex\">||(\\mathbf{E} = E^i \\gamma_i \\gamma_0||)</marimo-tex> (electric) and\n<marimo-tex class=\"arithmatex\">||(I\\mathbf{B}||)</marimo-tex> encodes the magnetic field via the pseudoscalar.</span></span>"
          }
        }
      ],
      "console": []
    },
    {
      "id": "TqIu",
      "code_hash": "9dedb4349026445e911a1786d4ff5c24",
      "outputs": [],
      "console": []
    },
    {
      "id": "Vxnm",
      "code_hash": "7d02823d87afa8f5e01b74e4b3b6b5a5",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h3 id=\"boosting-the-em-field\">Boosting the EM Field</h3>\n<span class=\"paragraph\">Under a Lorentz boost, <marimo-tex class=\"arithmatex\">||(F \\to R F \\tilde{R}||)</marimo-tex>. Drag the rapidity\nto see how the electric and magnetic fields mix.</span></span>"
          }
        }
      ],
      "console": []
    },
