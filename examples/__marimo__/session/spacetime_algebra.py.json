      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h1 id=\"spacetime-algebra-sta\">Spacetime Algebra (STA)</h1>\n<span class=\"paragraph\">The Spacetime Algebra is Cl(1,3) \u2014 one timelike dimension (<marimo-tex class=\"arithmatex\">||(\\gamma_0^2 = +1||)</marimo-tex>)\nand three spacelike (<marimo-tex class=\"arithmatex\">||(\\gamma_i^2 = -1||)</marimo-tex>). It encodes special relativity,\nelectromagnetism, and the Dirac equation in a single algebraic framework.</span></span>"
          }
        }
      ],
      "console": []
    },
