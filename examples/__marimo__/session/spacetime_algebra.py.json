          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"interactive-spatial-rotation\">Interactive Spatial Rotation</h2>\n<span class=\"paragraph\">Rotations in STA use spacelike bivectors (<marimo-tex class=\"arithmatex\">||(\\gamma_i \\gamma_j||)</marimo-tex>).\nThe rotor is <marimo-tex class=\"arithmatex\">||(R = \\cos(\\theta/2) - \\sin(\\theta/2)\\, \\gamma_1 \\gamma_2||)</marimo-tex>.</span></span>"
          }
        }
      ],
      "console": []
    },
